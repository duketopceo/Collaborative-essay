// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== NextAuth.js Adapter Models ==============

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== Application Models ==============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  bio           String?   @db.Text
  password      String?   // For credentials provider
  accounts      Account[]
  sessions      Session[]

  // Content relationships
  essays         Essay[]          @relation("Author")
  contributions  Contribution[]
  pullRequests   PullRequest[]    @relation("PRAuthor")
  reviews        Review[]
  comments       Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Essay {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  description    String?        @db.Text
  visibility     Visibility     @default(PUBLIC)

  // Current content (head)
  content    String         @db.Text
  structure  EssayStructure @default(SINGLE)

  // Versioning
  versions       Version[]
  currentVersion Int          @default(1)

  // Relationships
  author       User           @relation("Author", fields: [authorId], references: [id], onDelete: Cascade)
  authorId     String
  contributors Contribution[]
  pullRequests PullRequest[]
  sections     Section[]
  essayTags    EssayTag[]

  // Metadata
  viewCount  Int @default(0)
  forkCount  Int @default(0)
  starCount  Int @default(0)

  // Fork relationship
  forkedFrom   Essay?  @relation("Forks", fields: [forkedFromId], references: [id])
  forkedFromId String?
  forks        Essay[] @relation("Forks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id        String   @id @default(cuid())
  essay     Essay    @relation(fields: [essayId], references: [id], onDelete: Cascade)
  essayId   String
  title     String
  content   String   @db.Text
  order     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Version {
  id             String        @id @default(cuid())
  essay          Essay         @relation(fields: [essayId], references: [id], onDelete: Cascade)
  essayId        String
  versionNumber  Int
  content        String        @db.Text
  message        String?       @db.Text

  // What created this version
  source         VersionSource
  pullRequest    PullRequest?  @relation(fields: [pullRequestId], references: [id])
  pullRequestId  String?

  createdAt DateTime @default(now())
}

model PullRequest {
  id              String   @id @default(cuid())
  number          Int // PR number within essay
  title           String
  description     String?  @db.Text
  status          PRStatus @default(OPEN)

  // The proposed changes
  proposedContent String @db.Text
  diff            String @db.Text // Computed diff

  // Relationships
  essay   Essay @relation(fields: [essayId], references: [id], onDelete: Cascade)
  essayId String
  author  User  @relation("PRAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  // AI-specific fields
  isAIGenerated Boolean @default(false)
  aiModel       String?
  aiPrompt      String? @db.Text

  // Review process
  reviews   Review[]
  comments  Comment[]
  versions  Version[]

  // Merge info
  mergedAt DateTime?
  mergedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([essayId, number])
}

model Review {
  id             String       @id @default(cuid())
  pullRequest    PullRequest  @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  pullRequestId  String
  reviewer       User         @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId     String

  status ReviewStatus
  body   String? @db.Text

  // AI review fields
  isAIReview    Boolean @default(false)
  aiSuggestions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id             String        @id @default(cuid())
  body           String        @db.Text

  // Can be on PR or inline on content
  pullRequest    PullRequest?  @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  pullRequestId  String?
  lineNumber     Int? // For inline comments

  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  // AI comment
  isAIGenerated Boolean @default(false)

  // Threading
  parent   Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  replies  Comment[] @relation("CommentThread")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contribution {
  id         String @id @default(cuid())
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  essay      Essay  @relation(fields: [essayId], references: [id], onDelete: Cascade)
  essayId    String

  // Contribution stats
  additions  Int @default(0)
  deletions  Int @default(0)
  prCount    Int @default(0)

  @@unique([userId, essayId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  essays    EssayTag[]
  createdAt DateTime @default(now())
}

model EssayTag {
  essayId String
  tagId   String
  essay   Essay  @relation(fields: [essayId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([essayId, tagId])
}

// ============== Enums ==============

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum EssayStructure {
  SINGLE
  MULTI_SECTION
}

enum VersionSource {
  DIRECT_EDIT
  PR_MERGE
  AI_SUGGESTION
  FORK
}

enum PRStatus {
  OPEN
  MERGED
  CLOSED
  DRAFT
}

enum ReviewStatus {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
}
